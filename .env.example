# Copy this file to .env on the deployment host and adjust as needed.
# docker compose reads .env automatically.

# ---- Published image (set by the GitHub Actions build) ----
IMAGE=ghcr.io/mathewburnett/streamsite:latest

# ---- Host port mappings ----
WEB_PORT=80           # website + HLS playback on port 80
HTTP_PORT=8080        # website + HLS playback on port 8080
RTMP_PORT=1935        # RTMP ingest

# ---- Web root bind mount ----
# Host folder mapped to the served web root. Seeded from the image on first
# start; drop a replacement stream.png (or other assets) here to customise.
WWW_DIR=./www

# ---- Stream / website configuration (rendered into the page at startup) ----
STREAM_TITLE=Stream Site
STREAM_KEY=live
STREAM_PICTURE=stream.png

# HLS playback host. Leave EMPTY to serve from the same host the viewer used to
# load the page — this auto-targets the deploy host's own IP/hostname with no
# configuration. Set a value only if HLS is served from a different machine.
STREAM_HLS_HOST=
STREAM_HLS_PORT=8080
